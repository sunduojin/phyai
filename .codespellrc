[codespell]
ignore-words-list = ans, als, hel, boostrap, childs, te, vas, hsa, ment, cann, thi, makro, wil, bfloat, constexpr, cuda, dlpack, expt, forceinline, ifndef, linalg, ROCM, silu, torchao, flashinfer, nccl, mot, agibotworld, agibot, galbot, lerobot, robomind, franka, uncond, mimsave, denoiser, issubdtype, fromarray, pusht
skip = *.json,*.jsonl,*.patch,*.txt,*/third_party/*
